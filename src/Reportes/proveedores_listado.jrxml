<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="proveedores_listado" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f92c3a7a-7f02-4cc2-9dc6-5b424ea33f6b">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL"/>

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_proveedor,
  rtn_proveedor,
  telefono_proveedor,
  email_proveedor,
  direccion_proveedor,
  contacto_proveedor,
  estado_proveedor
FROM proveedores
ORDER BY nombre_proveedor
        ]]>
    </queryString>

    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="rtn_proveedor" class="java.lang.String"/>
    <field name="telefono_proveedor" class="java.lang.String"/>
    <field name="email_proveedor" class="java.lang.String"/>
    <field name="direccion_proveedor" class="java.lang.String"/>
    <field name="contacto_proveedor" class="java.lang.String"/>
    <field name="estado_proveedor" class="java.lang.Boolean"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[REPORTE DE PROVEEDORES]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="150" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Nombre]]></text></staticText>
            <staticText><reportElement x="150" y="0" width="80" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[RTN]]></text></staticText>
            <staticText><reportElement x="230" y="0" width="70" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Teléfono]]></text></staticText>
            <staticText><reportElement x="300" y="0" width="95" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Email]]></text></staticText>
            <staticText><reportElement x="395" y="0" width="110" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Contacto]]></text></staticText>
            <staticText><reportElement x="505" y="0" width="50" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Estado]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="150" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="150" y="0" width="80" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{rtn_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="230" y="0" width="70" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{telefono_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="300" y="0" width="95" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{email_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="395" y="0" width="110" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{contacto_proveedor}]]></textFieldExpression></textField>
            <textField>
                <reportElement x="505" y="0" width="50" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{estado_proveedor} ? "ACTIVO" : "INACTIVO"]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
