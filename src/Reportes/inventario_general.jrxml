<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="inventario_general" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6e31bb2b-7f6d-4bf6-9cfe-21c4a0fcafdf">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL"/>

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_decoracion,
  stock_decoracion,
  stock_minimo_decoracion,
  stock_maximo_decoracion,
  precio_costo_decoracion,
  precio_venta_decoracion,
  valor_total_inventario,
  estado_stock,
  nombre_proveedor,
  COALESCE(nombre_coleccion,'N/A') AS nombre_coleccion
FROM vista_detallada_inventario
ORDER BY nombre_decoracion
        ]]>
    </queryString>

    <field name="nombre_decoracion" class="java.lang.String"/>
    <field name="stock_decoracion" class="java.lang.Integer"/>
    <field name="stock_minimo_decoracion" class="java.lang.Integer"/>
    <field name="stock_maximo_decoracion" class="java.lang.Integer"/>
    <field name="precio_costo_decoracion" class="java.math.BigDecimal"/>
    <field name="precio_venta_decoracion" class="java.math.BigDecimal"/>
    <field name="valor_total_inventario" class="java.math.BigDecimal"/>
    <field name="estado_stock" class="java.lang.String"/>
    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="nombre_coleccion" class="java.lang.String"/>

    <variable name="valorTotalInventario" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{valor_total_inventario}]]></variableExpression>
    </variable>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[INVENTARIO GENERAL]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="160" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Decoración]]></text></staticText>
            <staticText><reportElement x="160" y="0" width="35" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[St]]></text></staticText>
            <staticText><reportElement x="195" y="0" width="45" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Costo]]></text></staticText>
            <staticText><reportElement x="240" y="0" width="45" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Venta]]></text></staticText>
            <staticText><reportElement x="285" y="0" width="55" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Valor]]></text></staticText>
            <staticText><reportElement x="340" y="0" width="65" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Estado]]></text></staticText>
            <staticText><reportElement x="405" y="0" width="90" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Proveedor]]></text></staticText>
            <staticText><reportElement x="495" y="0" width="60" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Colección]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="160" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="160" y="0" width="35" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="195" y="0" width="45" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{precio_costo_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="240" y="0" width="45" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{precio_venta_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="285" y="0" width="55" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{valor_total_inventario}]]></textFieldExpression></textField>
            <textField><reportElement x="340" y="0" width="65" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{estado_stock}]]></textFieldExpression></textField>
            <textField><reportElement x="405" y="0" width="90" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="495" y="0" width="60" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_coleccion}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="22">
            <staticText>
                <reportElement x="0" y="0" width="285" height="22"/>
                <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[VALOR TOTAL INVENTARIO:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="285" y="0" width="270" height="22"/>
                <textElement textAlignment="Left"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$V{valorTotalInventario}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
