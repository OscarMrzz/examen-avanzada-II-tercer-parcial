                        </jr:detailCell>
                    </jr:column>
                    <jr:column width="100" uuid="8a0bb747-8bb8-4e30-9a2c-516aeab9c2b2">
                        <jr:columnHeader height="18">
                            <staticText><reportElement x="0" y="0" width="100" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Subtotal]]></text></staticText>
