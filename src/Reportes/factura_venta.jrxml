                        </jr:detailCell>
                    </jr:column>
                </jr:table>
            </componentElement>

            <staticText><reportElement x="310" y="170" width="120" height="14"/><textElement textAlignment="Right"><font isBold="true" size="10"/></textElement><text><![CDATA[Subtotal:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="430" y="170" width="125" height="14"/><textElement textAlignment="Right"><font size="10"/></textElement><textFieldExpression><![CDATA[$F{subtotal_venta}]]></textFieldExpression></textField>

            <staticText><reportElement x="310" y="186" width="120" height="14"/><textElement textAlignment="Right"><font isBold="true" size="10"/></textElement><text><![CDATA[Impuesto (18%):]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="430" y="186" width="125" height="14"/><textElement textAlignment="Right"><font size="10"/></textElement><textFieldExpression><![CDATA[$F{impuesto_venta}]]></textFieldExpression></textField>

            <staticText><reportElement x="310" y="202" width="120" height="14"/><textElement textAlignment="Right"><font isBold="true" size="10"/></textElement><text><![CDATA[Descuento:]]></text></staticText>
