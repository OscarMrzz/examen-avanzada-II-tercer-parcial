                        </jr:columnHeader>
                        <jr:detailCell height="16">
                            <textField pattern="#,##0.00"><reportElement x="0" y="0" width="80" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{precio_unitario_venta}]]></textFieldExpression></textField>
