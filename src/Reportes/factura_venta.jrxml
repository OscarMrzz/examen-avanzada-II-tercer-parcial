                        <jr:detailCell height="16">
                            <textField><reportElement x="0" y="0" width="60" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{cantidad_detalle_venta}]]></textFieldExpression></textField>
                        </jr:detailCell>
