                        </jr:columnHeader>
                        <jr:detailCell height="16">
                            <textField><reportElement x="0" y="0" width="245" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
                        </jr:detailCell>
                    </jr:column>
                    <jr:column width="60" uuid="c0ee33b1-5c70-4a0d-8a4a-86dfc76f7a31">
