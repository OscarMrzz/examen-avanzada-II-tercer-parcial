<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="inventario_por_proveedor" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d9c7f5db-4e91-413e-8aa6-0f7dd45278a4">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="nombreProveedor" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_proveedor,
  nombre_decoracion,
  nombre_coleccion,
  stock_decoracion,
  stock_minimo_decoracion,
  precio_compra_decoracion,
  precio_venta_decoracion,
  (stock_decoracion * precio_compra_decoracion) AS valor_inventario_costo
FROM vista_detallada_inventario
WHERE ($P{nombreProveedor} IS NULL OR nombre_proveedor = $P{nombreProveedor})
ORDER BY nombre_proveedor, nombre_decoracion
        ]]>
    </queryString>

    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="nombre_decoracion" class="java.lang.String"/>
    <field name="nombre_coleccion" class="java.lang.String"/>
    <field name="stock_decoracion" class="java.lang.Integer"/>
    <field name="stock_minimo_decoracion" class="java.lang.Integer"/>
    <field name="precio_compra_decoracion" class="java.math.BigDecimal"/>
    <field name="precio_venta_decoracion" class="java.math.BigDecimal"/>
    <field name="valor_inventario_costo" class="java.math.BigDecimal"/>

    <title>
        <band height="64">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[INVENTARIO POR PROVEEDOR]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="44" width="555" height="14"/>
                <textElement textAlignment="Center"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[
($P{nombreProveedor} == null ? "Proveedor: (todos)" : ("Proveedor: " + $P{nombreProveedor}))
                ]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="95" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Proveedor]]></text></staticText>
            <staticText><reportElement x="95" y="0" width="190" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Decoración]]></text></staticText>
            <staticText><reportElement x="285" y="0" width="90" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Colección]]></text></staticText>
            <staticText><reportElement x="375" y="0" width="45" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Stock]]></text></staticText>
            <staticText><reportElement x="420" y="0" width="70" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Costo]]></text></staticText>
            <staticText><reportElement x="490" y="0" width="65" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Valor]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="95" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="95" y="0" width="190" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="285" y="0" width="90" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_coleccion}]]></textFieldExpression></textField>
            <textField><reportElement x="375" y="0" width="45" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="420" y="0" width="70" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{precio_compra_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="490" y="0" width="65" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{valor_inventario_costo}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
