<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="inventario_valor_total" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="f594d765-6dbf-4f90-9aa8-f2d37570cc8c">

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  COUNT(*) AS cantidad_items,
  SUM(stock_decoracion * precio_compra_decoracion) AS valor_total_costo,
  SUM(stock_decoracion * precio_venta_decoracion) AS valor_total_venta
FROM vista_detallada_inventario
        ]]>
    </queryString>

    <field name="cantidad_items" class="java.lang.Long"/>
    <field name="valor_total_costo" class="java.math.BigDecimal"/>
    <field name="valor_total_venta" class="java.math.BigDecimal"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[VALOR TOTAL DEL INVENTARIO]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <detail>
        <band height="120">
            <staticText><reportElement x="0" y="10" width="220" height="18"/><textElement><font isBold="true" size="11"/></textElement><text><![CDATA[Cantidad de ítems]]></text></staticText>
            <textField><reportElement x="240" y="10" width="315" height="18"/><textElement textAlignment="Right"><font size="11"/></textElement><textFieldExpression><![CDATA[$F{cantidad_items}]]></textFieldExpression></textField>

            <staticText><reportElement x="0" y="42" width="220" height="18"/><textElement><font isBold="true" size="11"/></textElement><text><![CDATA[Valor total (costo)]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="240" y="42" width="315" height="18"/><textElement textAlignment="Right"><font size="11"/></textElement><textFieldExpression><![CDATA[$F{valor_total_costo}]]></textFieldExpression></textField>

            <staticText><reportElement x="0" y="74" width="220" height="18"/><textElement><font isBold="true" size="11"/></textElement><text><![CDATA[Valor total (venta)]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="240" y="74" width="315" height="18"/><textElement textAlignment="Right"><font size="11"/></textElement><textFieldExpression><![CDATA[$F{valor_total_venta}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
