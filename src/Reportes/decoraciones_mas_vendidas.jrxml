<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="decoraciones_mas_vendidas" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="58f0791c-8bfe-4d83-93cd-2b3b23dd6a02">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL"/>

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_decoracion,
  COALESCE(nombre_coleccion,'N/A') AS nombre_coleccion,
  nombre_proveedor,
  total_unidades_vendidas,
  total_ventas_generadas
FROM vista_decoraciones_mas_vendidas
ORDER BY total_unidades_vendidas DESC
        ]]>
    </queryString>

    <field name="nombre_decoracion" class="java.lang.String"/>
    <field name="nombre_coleccion" class="java.lang.String"/>
    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="total_unidades_vendidas" class="java.lang.Long"/>
    <field name="total_ventas_generadas" class="java.math.BigDecimal"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[DECORACIONES MÁS VENDIDAS]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="200" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Decoración]]></text></staticText>
            <staticText><reportElement x="200" y="0" width="120" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Colección]]></text></staticText>
            <staticText><reportElement x="320" y="0" width="110" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Proveedor]]></text></staticText>
            <staticText><reportElement x="430" y="0" width="60" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Unid.]]></text></staticText>
            <staticText><reportElement x="490" y="0" width="65" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Total]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="200" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="200" y="0" width="120" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_coleccion}]]></textFieldExpression></textField>
            <textField><reportElement x="320" y="0" width="110" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="430" y="0" width="60" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{total_unidades_vendidas}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00">
                <reportElement x="490" y="0" width="65" height="16"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{total_ventas_generadas}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="260">
            <barChart>
                <chart>
                    <reportElement x="0" y="0" width="555" height="240"/>
                    <chartTitle>
                        <titleExpression><![CDATA["Top - Unidades vendidas"]]></titleExpression>
                    </chartTitle>
                </chart>
                <categoryDataset>
                    <categorySeries>
                        <seriesExpression><![CDATA["Unidades"]]></seriesExpression>
                        <categoryExpression><![CDATA[$F{nombre_decoracion}]]></categoryExpression>
                        <valueExpression><![CDATA[$F{total_unidades_vendidas}]]></valueExpression>
                    </categorySeries>
                </categoryDataset>
                <barPlot>
                    <plot/>
                </barPlot>
            </barChart>
        </band>
    </summary>
</jasperReport>
