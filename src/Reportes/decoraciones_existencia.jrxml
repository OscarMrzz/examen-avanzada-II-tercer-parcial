<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="decoraciones_existencia" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c9d3b7d4-0e43-4bcb-9bdf-42af4de8b8de">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="MySQL"/>

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_decoracion,
  stock_decoracion,
  stock_minimo_decoracion,
  stock_maximo_decoracion,
  nombre_proveedor,
  COALESCE(nombre_coleccion,'N/A') AS nombre_coleccion,
  estado_stock
FROM vista_detallada_inventario
WHERE stock_decoracion > 0
ORDER BY nombre_decoracion
        ]]>
    </queryString>

    <field name="nombre_decoracion" class="java.lang.String"/>
    <field name="stock_decoracion" class="java.lang.Integer"/>
    <field name="stock_minimo_decoracion" class="java.lang.Integer"/>
    <field name="stock_maximo_decoracion" class="java.lang.Integer"/>
    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="nombre_coleccion" class="java.lang.String"/>
    <field name="estado_stock" class="java.lang.String"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[DECORACIONES EN EXISTENCIA]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="160" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Decoración]]></text></staticText>
            <staticText><reportElement x="160" y="0" width="40" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Stock]]></text></staticText>
            <staticText><reportElement x="200" y="0" width="40" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Min]]></text></staticText>
            <staticText><reportElement x="240" y="0" width="40" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Max]]></text></staticText>
            <staticText><reportElement x="280" y="0" width="120" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Proveedor]]></text></staticText>
            <staticText><reportElement x="400" y="0" width="100" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Colección]]></text></staticText>
            <staticText><reportElement x="500" y="0" width="55" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Estado]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="160" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="160" y="0" width="40" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="200" y="0" width="40" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_minimo_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="240" y="0" width="40" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_maximo_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="280" y="0" width="120" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="400" y="0" width="100" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_coleccion}]]></textFieldExpression></textField>
            <textField><reportElement x="500" y="0" width="55" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{estado_stock}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="200" height="18"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Registros: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="355" y="0" width="200" height="18"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
