<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="compras_resumen_mensual" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="d680c6f4-79f9-4dcd-8e80-76e55a8e6e5c">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="anio" class="java.lang.Integer"/>

    <queryString>
        <![CDATA[
SELECT
  YEAR(fecha_factura_compra) AS anio,
  MONTH(fecha_factura_compra) AS mes_num,
  DATE_FORMAT(fecha_factura_compra, '%Y-%m') AS mes,
  COUNT(numero_factura) AS cantidad_compras,
  SUM(total_factura_compra) AS total_compras
FROM vista_detallada_compras
WHERE ($P{anio} IS NULL OR YEAR(fecha_factura_compra) = $P{anio})
GROUP BY YEAR(fecha_factura_compra), MONTH(fecha_factura_compra), DATE_FORMAT(fecha_factura_compra, '%Y-%m')
ORDER BY anio DESC, mes_num DESC
        ]]>
    </queryString>

    <field name="anio" class="java.lang.Integer"/>
    <field name="mes_num" class="java.lang.Integer"/>
    <field name="mes" class="java.lang.String"/>
    <field name="cantidad_compras" class="java.lang.Long"/>
    <field name="total_compras" class="java.math.BigDecimal"/>

    <title>
        <band height="58">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[RESUMEN MENSUAL DE COMPRAS]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="44" width="555" height="14"/>
                <textElement textAlignment="Center"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[
($P{anio} == null) ? "Año: (todos)" : ("Año: " + $P{anio})
                ]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="120" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Mes]]></text></staticText>
            <staticText><reportElement x="120" y="0" width="120" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[# Compras]]></text></staticText>
            <staticText><reportElement x="240" y="0" width="140" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Total]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="120" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{mes}]]></textFieldExpression></textField>
            <textField><reportElement x="120" y="0" width="120" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{cantidad_compras}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="240" y="0" width="140" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{total_compras}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
