<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="inventario_stock_bajo" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="88f36a6e-f5a2-4ca6-82c1-74b6bb7ad36d">

    <parameter name="titulo" class="java.lang.String"/>

    <queryString>
        <![CDATA[
SELECT
  nombre_decoracion,
  nombre_coleccion,
  nombre_proveedor,
  stock_decoracion,
  stock_minimo_decoracion,
  precio_compra_decoracion,
  precio_venta_decoracion
FROM vista_detallada_inventario
WHERE stock_decoracion <= stock_minimo_decoracion
ORDER BY (stock_minimo_decoracion - stock_decoracion) DESC, stock_decoracion ASC
        ]]>
    </queryString>

    <field name="nombre_decoracion" class="java.lang.String"/>
    <field name="nombre_coleccion" class="java.lang.String"/>
    <field name="nombre_proveedor" class="java.lang.String"/>
    <field name="stock_decoracion" class="java.lang.Integer"/>
    <field name="stock_minimo_decoracion" class="java.lang.Integer"/>
    <field name="precio_compra_decoracion" class="java.math.BigDecimal"/>
    <field name="precio_venta_decoracion" class="java.math.BigDecimal"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="22"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[INVENTARIO - STOCK BAJO]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="26" width="555" height="18"/>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="18">
            <staticText><reportElement x="0" y="0" width="185" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Decoración]]></text></staticText>
            <staticText><reportElement x="185" y="0" width="95" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Colección]]></text></staticText>
            <staticText><reportElement x="280" y="0" width="120" height="18"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Proveedor]]></text></staticText>
            <staticText><reportElement x="400" y="0" width="45" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Stock]]></text></staticText>
            <staticText><reportElement x="445" y="0" width="55" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Mín]]></text></staticText>
            <staticText><reportElement x="500" y="0" width="55" height="18"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Venta]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="16">
            <textField><reportElement x="0" y="0" width="185" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="185" y="0" width="95" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_coleccion}]]></textFieldExpression></textField>
            <textField><reportElement x="280" y="0" width="120" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{nombre_proveedor}]]></textFieldExpression></textField>
            <textField><reportElement x="400" y="0" width="45" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_decoracion}]]></textFieldExpression></textField>
            <textField><reportElement x="445" y="0" width="55" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{stock_minimo_decoracion}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="500" y="0" width="55" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{precio_venta_decoracion}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
